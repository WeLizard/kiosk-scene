{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://welizard.dev/schemas/kiosk-scene/control.schema.json",
  "title": "kiosk-scene control v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "revision",
    "page",
    "cue"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 0
    },
    "viewPreset": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "full",
        "torso",
        "head",
        null
      ]
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "target",
        "until"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "auto",
            "pinned"
          ]
        },
        "target": {
          "type": [
            "string",
            "null"
          ]
        },
        "until": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "cue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "emotion",
        "motion",
        "until"
      ],
      "properties": {
        "cue": {
          "type": [
            "string",
            "null"
          ]
        },
        "emotion": {
          "type": [
            "string",
            "null"
          ]
        },
        "motion": {
          "type": [
            "string",
            "null"
          ]
        },
        "until": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    }
  }
}
